{
  "name": "greenpro-backend",
  "version": "1.0.0",
  "description": "Production-ready NestJS backend for GreenPro",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "prestart": "node scripts/block-host-nest-start.mjs",
    "start": "nest start --watch --entryFile src/main",
    "prestart:once": "node scripts/block-host-nest-start.mjs",
    "start:once": "nest start --entryFile src/main",
    "start:dev": "node scripts/docker-dev-up.mjs",
    "start:dev:container": "nest start --watch --entryFile src/main",
    "prestart:debug": "node scripts/block-host-nest-start.mjs",
    "start:debug": "nest start --debug --watch --entryFile src/main",
    "start:prod": "node dist/src/main.js",
    "start:prod:docker": "docker compose -f docker-compose.yml up --build api redis",
    "docker:up": "node scripts/docker-dev-up.mjs --detach",
    "docker:down": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down",
    "docker:logs": "docker compose -f docker-compose.yml -f docker-compose.dev.yml logs -f api",
    "docker:restart": "docker compose -f docker-compose.yml -f docker-compose.dev.yml restart api",
    "seed:greenpro": "ts-node -r tsconfig-paths/register src/scripts/seed-greenpro-user.ts",
    "seed:platform-admin": "ts-node -r tsconfig-paths/register src/scripts/seed-platform-admin-user.ts",
    "migrate:platform-portal-users": "ts-node -r tsconfig-paths/register src/scripts/migrate-platform-portal-users.ts",
    "migrate:vendor-users:manufacturer-id": "ts-node -r tsconfig-paths/register src/scripts/backfill-vendor-users-manufacturer-id.ts",
    "migrate:certification-doc-versions": "ts-node -r tsconfig-paths/register src/scripts/backfill-certification-document-versions.ts",
    "migrate:mysql": "ts-node -r tsconfig-paths/register src/scripts/mysql-migration/run-migration.ts",
    "migrate:mysql:list": "ts-node -r tsconfig-paths/register src/scripts/mysql-migration/run-migration.ts -- --list",
    "migrate:mysql:validate": "ts-node -r tsconfig-paths/register src/scripts/mysql-migration/validate-counts.ts",
    "migrate:mysql:analyze": "node scripts/analyze-sql-dump.mjs \"greenpro (16).sql\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1024.0",
    "@nestjs/cache-manager": "^3.1.2",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mongoose": "^10.0.2",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/swagger": "^7.1.17",
    "archiver": "^8.0.0",
    "axios": "^1.6.2",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^2.4.3",
    "cache-manager": "^7.2.8",
    "cache-manager-redis-yet": "^5.1.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cors": "^2.8.6",
    "exceljs": "^4.4.0",
    "ioredis": "^5.10.1",
    "mongodb": "^7.1.1",
    "mongoose": "^8.0.3",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.8",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.18.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.3.1",
    "@types/nodemailer": "^6.4.14",
    "@types/passport-jwt": "^4.0.1",
    "@types/pdfkit": "^0.17.6",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "mysql2": "^3.22.5",
    "prettier": "^3.0.0",
    "puppeteer": "^24.40.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
