# Copy to `.env.migration` and fill in values.
# NEVER point MIGRATION_MONGO_URI at your live production database during testing.

# --- Separate migration MongoDB (required) ---
MIGRATION_MONGO_URI=mongodb://127.0.0.1:27017/greenpro_migration

# Live app URI (used only for safety guard — migration refuses if same as MIGRATION_MONGO_URI)
MONGODB_URI=mongodb+srv://user:pass@cluster/greenpro_live

# Set true only when you intentionally target the live DB (not recommended)
ALLOW_LIVE_TARGET=false

# --- Staging MySQL (after loading greenpro (16).sql) ---
MYSQL_MIGRATION_HOST=127.0.0.1
MYSQL_MIGRATION_PORT=3307
MYSQL_MIGRATION_USER=greenpro
MYSQL_MIGRATION_PASSWORD=greenpro
MYSQL_MIGRATION_DATABASE=greenpro

# --- Options ---
MIGRATION_BATCH_SIZE=500
MIGRATION_DRY_RUN=false
