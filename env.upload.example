# Optional: if ALL are set, file uploads use AWS S3; otherwise files go to ./uploads/
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your-bucket-name

# Public CDN URL for uploaded files (certified product images, categories, etc.)
# Example: https://d111111abcdef8.cloudfront.net
AWS_CLOUDFRONT_URL=

# Set to true only if you intentionally want direct S3 URLs instead of CloudFront
# AWS_S3_USE_DIRECT_PUBLIC_URL=false
